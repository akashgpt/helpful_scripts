## INCAR template for single-GPU VASP runs
## Key GPU-specific settings are marked with [GPU]

SYSTEM = your_system_name


Start parameter for this Run:
  NWRITE =  2;  LPETIM=F
  ISTART =  0                 job   : 0-new  1-cont  2-samecut
  LWAVE  =  .FALSE.
  LCHARG =  .FALSE.


Cluster dependent:
  NPAR   =  1                [GPU] Must be 1 for GPU VASP (offloads to GPU, not MPI-parallel bands)
  NSIM   =  32               [GPU] Larger NSIM saturates GPU better (default 4 is too small; 32 is good)
  KPAR   =  1                [GPU] Set to number of GPUs (1 for single-GPU)


Electronic Relaxation:
  ENCUT  =  800.00 EV        adjust for your system
  NELM   =  150
  EDIFF  =  1E-06
  ALGO   =  N
  LREAL  =  A


Ionic Relaxation:
  NSW    =  0                0 for single-point, >0 for MD/relaxation
  ISYM   =  0
  ISIF   =  2

  POTIM  =  1.000
  TEBEG  =  8000             initial temperature (for MD)
  SMASS  =  0.00


DOS related values:
  ISMEAR =  -1
  SIGMA  = 0.689387


## Notes:
## - NPAR must always be 1 for GPU VASP.
## - NSIM=32 is optimal for A100 GPUs. NSIM=16 is ~2% slower, NSIM=64 is ~same.
## - KPAR should equal number of GPUs and divide NKPTS evenly.
## - NBANDS: let VASP auto-determine unless you have a specific reason to set it.
## - CPU count per GPU has negligible effect (1 CPU vs 16 CPUs: ~same wall time).
