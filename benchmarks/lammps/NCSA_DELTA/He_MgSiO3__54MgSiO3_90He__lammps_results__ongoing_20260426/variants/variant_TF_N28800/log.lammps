  use deepmd-kit at:  /work/nvme/bguf/agupta46/softwares/conda_envs_dir_secondary/envs/ALCHEMY_env
  source:             
  source branch:      
  source commit:      
  source commit at:   
  build with inc:     
  build with lib:     
pair_coeff      * *

# Equilibration
reset_timestep  0
velocity        all create ${T1} 6149
velocity        all create 3200 6149
fix             NPTSTATE all npt temp ${T1} ${T1} ${TAU_T} iso ${P1} ${P1} ${TAU_P}
fix             NPTSTATE all npt temp 3200 ${T1} ${TAU_T} iso ${P1} ${P1} ${TAU_P}
fix             NPTSTATE all npt temp 3200 3200 ${TAU_T} iso ${P1} ${P1} ${TAU_P}
fix             NPTSTATE all npt temp 3200 3200 0.01 iso ${P1} ${P1} ${TAU_P}
fix             NPTSTATE all npt temp 3200 3200 0.01 iso 1000000 ${P1} ${TAU_P}
fix             NPTSTATE all npt temp 3200 3200 0.01 iso 1000000 1000000 ${TAU_P}
fix             NPTSTATE all npt temp 3200 3200 0.01 iso 1000000 1000000 0.1
timestep        ${TIMESTEP}
timestep        0.0005
thermo          ${THERMO_FREQ}
thermo          100
thermo_style    custom step temp press vol etotal ke pe enthalpy
run             ${NSTEPS_relax}
run             20

