package kokkos
package kokkos newton on neigh half
############################################################
# KOKKOS benchmark input — shortened version of the
# testing__LAMMPS/.../in.lammps (single NPT loop, 5k steps).
#
# Model is set via the LAMMPS variable ${MODEL} (injected at
# runtime via `lmp -var MODEL <path>`), so the same input
# drives both PT (.pth) and PT+KOKKOS runs without editing.
############################################################

echo            both

variable        T1                  equal 3200
variable        T2                  equal 4800
variable        P1                  equal 100E4
variable        P2                  equal 10E4

variable        TEMP                equal ((${T1}+${T2})/2)
variable        TEMP                equal ((3200+${T2})/2)
variable        TEMP                equal ((3200+4800)/2)
variable        PRES                equal ((${P1}+${P2})/2)
variable        PRES                equal ((1000000+${P2})/2)
variable        PRES                equal ((1000000+100000)/2)

variable        TIMESTEP            equal 0.5e-3
variable        THERMO_FREQ         equal 100
variable        DUMP_FREQ           equal 500
variable        NSTEPS_relax        index 200
variable        NSTEPS_4training    index 5000
variable        TAU_T               equal 0.0100000
variable        TAU_P               equal 0.100000

variable        kBeV                equal 8.617333262e-5
variable        TeV                 equal ${TEMP}*${kBeV}
variable        TeV                 equal 4000*${kBeV}
variable        TeV                 equal 4000*8.617333262e-05

units           metal
boundary        p p p
atom_style      atomic
neighbor        1.0 bin
neigh_modify    every 1 delay 0 check no

read_data       conf.lmp
Reading data file ...
  orthogonal box = (0 0 0) to (14.01 14.01 13.28)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  360 atoms
  read_data CPU = 0.006 seconds

# ${MODEL} is injected via `lmp -var MODEL <path>` from the sub script.
pair_style      deepmd ${MODEL} fparam ${TeV}
pair_style      deepmd /work/nvme/bguf/akashgpt/softwares/installing_MLMD_related_stuff/deepmd-kit__w_plumed/testing__LAMMPS__kokkos_bench/He_MgSiO3__54MgSiO3_90He/shared/model_comp.pth fparam ${TeV}
pair_style      deepmd /work/nvme/bguf/akashgpt/softwares/installing_MLMD_related_stuff/deepmd-kit__w_plumed/testing__LAMMPS__kokkos_bench/He_MgSiO3__54MgSiO3_90He/shared/model_comp.pth fparam 0.34469333048
