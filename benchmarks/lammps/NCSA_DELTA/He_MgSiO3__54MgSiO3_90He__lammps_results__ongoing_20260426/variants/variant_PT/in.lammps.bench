############################################################
# KOKKOS benchmark input — shortened version of the
# testing__LAMMPS/.../in.lammps (single NPT loop, 5k steps).
#
# Model is set via the LAMMPS variable ${MODEL} (injected at
# runtime via `lmp -var MODEL <path>`), so the same input
# drives both PT (.pth) and PT+KOKKOS runs without editing.
############################################################

echo            both

variable        T1                  equal 3200
variable        T2                  equal 4800
variable        P1                  equal 100E4
variable        P2                  equal 10E4

variable        TEMP                equal ((${T1}+${T2})/2)
variable        PRES                equal ((${P1}+${P2})/2)

variable        TIMESTEP            equal 0.5e-3
variable        THERMO_FREQ         equal 100
variable        DUMP_FREQ           equal 500
variable        NSTEPS_relax        equal 200
variable        NSTEPS_4training    equal 5000
variable        TAU_T               equal 0.0100000
variable        TAU_P               equal 0.100000

variable        kBeV                equal 8.617333262e-5
variable        TeV                 equal ${TEMP}*${kBeV}

units           metal
boundary        p p p
atom_style      atomic
neighbor        1.0 bin
neigh_modify    every 1 delay 0 check no

read_data       conf.lmp

# ${MODEL} is injected via `lmp -var MODEL <path>` from the sub script.
pair_style      deepmd ${MODEL} fparam ${TeV}
pair_coeff      * *

# Equilibration
reset_timestep  0
velocity        all create ${T1} 6149
fix             NPTSTATE all npt temp ${T1} ${T1} ${TAU_T} iso ${P1} ${P1} ${TAU_P}
timestep        ${TIMESTEP}
thermo          ${THERMO_FREQ}
thermo_style    custom step temp press vol etotal ke pe enthalpy
run             ${NSTEPS_relax}
unfix           NPTSTATE

# Main timed loop — this is the number used for the ms/step metric.
velocity        all create ${T1} 6149
fix             4TRAINING all npt temp ${T1} ${T2} ${TAU_T} iso ${P1} ${P2} ${TAU_P}
timestep        ${TIMESTEP}
thermo          ${THERMO_FREQ}
thermo_style    custom step temp press vol etotal ke pe enthalpy
dump            myDUMP all custom ${DUMP_FREQ} npt.dump id type element x y z
dump_modify     myDUMP sort id
dump_modify     myDUMP element Mg Si O He
run             ${NSTEPS_4training}
unfix           4TRAINING
undump          myDUMP

write_data      conf.lmp.end
