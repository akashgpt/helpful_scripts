fix             4TRAINING all npt temp 3200 4800 0.01 iso 1000000 100000 ${TAU_P}
fix             4TRAINING all npt temp 3200 4800 0.01 iso 1000000 100000 0.1
timestep        ${TIMESTEP}
timestep        0.0005
thermo          ${THERMO_FREQ}
thermo          100
thermo_style    custom step temp press vol etotal ke pe enthalpy
dump            myDUMP all custom ${DUMP_FREQ} npt.dump id type element x y z
dump            myDUMP all custom 500 npt.dump id type element x y z
dump_modify     myDUMP sort id
dump_modify     myDUMP element Mg Si O He
run             ${NSTEPS_4training}
run             5000
