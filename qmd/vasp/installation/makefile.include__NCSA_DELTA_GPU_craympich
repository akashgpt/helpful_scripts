# =============================================================================
# VASP 6.6.0 GPU makefile.include — NCSA Delta RH9, Cray MPICH path
# =============================================================================
# Target hardware : NVIDIA A100-SXM4 on Delta GPU nodes (cc80)
# Compiler stack  : PrgEnv-nvidia 8.6.0 + Cray MPICH 8.1.32 + CUDA 12.8
# Math libs       : Cray LibSci + Cray FFTW
# HDF5            : disabled
#
# This variant follows Delta's documented programming environment more closely
# than the HPC-X/OpenMPI build. The goal is to test whether the remaining
# 2-GPU slowdown is tied to the current HPC-X multi-GPU communication stack.
#
# Recommended module baseline before building AND running:
#	module purge
#	module load PrgEnv-nvidia/8.6.0 craype-x86-milan cudatoolkit/25.3_12.8
#
# Notes:
#	- PrgEnv-nvidia auto-loads Cray MPICH and Cray LibSci on Delta.
#	- The Cray wrappers provide BLAS/LAPACK/ScaLAPACK automatically.
#	- We keep NCCL enabled to preserve the same VASP GPU communication model
#	  while swapping only the MPI/runtime layer.
# =============================================================================

CPP_OPTIONS = -DHOST=\"LinuxNV\" \
	-DMPI -DMPI_INPLACE -DMPI_BLOCK=8000 -Duse_collective \
	-DscaLAPACK \
	-DCACHE_SIZE=4000 \
	-Davoidalloc \
	-Dvasp6 \
	-Dtbdyn \
	-Dqd_emulate \
	-Dfock_dblbuf \
	-D_OPENMP \
	-DACC_OFFLOAD \
	-DNVCUDA \
	-DUSENCCL

CPP         = nvfortran -Mpreprocess -Mfree -Mextend -E $(CPP_OPTIONS) $*$(FUFFIX) > $*$(SUFFIX)

GPU        ?= -gpu=cc80,cuda12.8
VASP_TARGET_CPU ?= -tp zen3

CC          = cc  -mp -acc $(GPU) $(VASP_TARGET_CPU)
FC          = ftn -mp -acc $(GPU) $(VASP_TARGET_CPU)
FCL         = ftn -mp -acc $(GPU) $(VASP_TARGET_CPU) -c++libs

FREE        = -Mfree
FFLAGS      = -Mbackslash -Mlarge_arrays

OFLAG       = -O2 -Munroll -Mlre -Mvect=simd $(VASP_TARGET_CPU)
OFLAG_IN    = -O2 -Munroll -Mlre -Mvect=simd -Mwarperf $(VASP_TARGET_CPU)
SOURCE_IN  := nonlr.o

DEBUG       = -Mfree -O0 -traceback

LLIBS       = -cudalib=cublas,cusolver,cufft,nccl -cuda -lmpi_gtl_cuda

SOURCE_O1  := pade_fit.o minimax_dependence.o wave_window.o
SOURCE_O2  := pead.o

CPP_LIB     = $(CPP)
FC_LIB      = $(FC)
CC_LIB      = $(CC)
CFLAGS_LIB  = -O -w $(VASP_TARGET_CPU)
FFLAGS_LIB  = -O1 -Mfixed $(VASP_TARGET_CPU)
FREE_LIB    = $(FREE)

OBJECTS_LIB = linpack_double.o

CXX_PARS    = CC $(VASP_TARGET_CPU)
LLIBS      += -lstdc++

NVROOT      = $(shell which nvfortran | awk -F /compilers/bin/nvfortran '{ print $$1 }')

QD         ?= $(NVROOT)/compilers/extras/qd
LLIBS      += -Wl,-rpath,$(QD)/lib -L$(QD)/lib -lqdmod -lqd
INCS       += -I$(QD)/include/qd

FFTW_ROOT  ?= /opt/cray/pe/fftw/default/x86_milan
LLIBS      += -L$(FFTW_ROOT)/lib -lfftw3 -lfftw3_omp
INCS       += -I$(FFTW_ROOT)/include

NVFORTRAN_VERSION := $(shell nvfortran --version | sed -n '2s/^nvfortran \([0-9.]*\).*/\1/p')
define greater_or_equal
$(shell printf '%s\n%s\n' '$(1)' '$(2)' | sort -V | head -n1 | grep -q '$(2)' && echo true || echo false)
endef
ifeq ($(call greater_or_equal,$(NVFORTRAN_VERSION),25.1),true)
	CC += -gpu=tripcount:host
	FC += -gpu=tripcount:host
endif
