# =============================================================================
# VASP 6.6.0 GPU makefile.include — Della cluster (Princeton)
# =============================================================================
# Target hardware : NVIDIA A100 (cc80), PCIE-40GB and 80GB variants
# Compiler stack  : NVHPC 25.5 + system OpenMPI 4.1.8 (CUDA-aware, cuda-12.9)
# Math libs       : Intel MKL 2024.2 (BLAS, LAPACK, ScaLAPACK, FFTW)
# HDF5            : disabled
#
# Based on arch/makefile.include.nvhpc_ompi_mkl_omp_acc
# MKL provides runtime CPU dispatch (works on both Intel and AMD nodes).
#
# Modules to load before compiling AND running:
#   module purge
#   module load nvhpc/25.5
#   module load openmpi/cuda-12.9/nvhpc-25.5/4.1.8
#   module load intel-mkl/2024.2
# =============================================================================

# --- Preprocessor options ---
CPP_OPTIONS = -DHOST=\"LinuxNV\" \
              -DMPI -DMPI_INPLACE -DMPI_BLOCK=8000 -Duse_collective \
              -DscaLAPACK \
              -DCACHE_SIZE=4000 \
              -Davoidalloc \
              -Dvasp6 \
              -Dtbdyn \
              -Dqd_emulate \
              -Dfock_dblbuf \
              -D_OPENMP \
              -DACC_OFFLOAD \
              -DNVCUDA \
              -DUSENCCL

CPP         = nvfortran -Mpreprocess -Mfree -Mextend -E $(CPP_OPTIONS) $*$(FUFFIX)  > $*$(SUFFIX)

# --- GPU target: A100 = cc80, CUDA 12.9 bundled with NVHPC 25.5 ---
GPU        ?= -gpu=cc80,cuda12.9

# --- CPU target (MUST be set before compilers) ---
# Della GPU nodes: mix of AMD Rome (zen2) and Intel Icelake.
# Use x86-64-v3 (generic AVX2) for portability across both architectures.
# CRITICAL: must appear in ALL compiler commands to avoid "Illegal instruction".
VASP_TARGET_CPU ?= -tp x86-64-v3

# --- Compilers (all carry -tp x86-64-v3) ---
CC          = mpicc  -mp -acc $(GPU) $(VASP_TARGET_CPU)
FC          = mpif90 -mp -acc $(GPU) $(VASP_TARGET_CPU)
FCL         = mpif90 -mp -acc $(GPU) $(VASP_TARGET_CPU) -c++libs

FREE        = -Mfree

FFLAGS      = -Mbackslash -Mlarge_arrays

# NOTE: -fast implies -tp host, so we replace it with its components + target CPU
OFLAG       = -O2 -Munroll -Mlre -Mvect=simd $(VASP_TARGET_CPU)

# Performance optimization for NVHPC >=21.11 and CUDA >11.2
OFLAG_IN    = -O2 -Munroll -Mlre -Mvect=simd -Mwarperf $(VASP_TARGET_CPU)
SOURCE_IN  := nonlr.o

DEBUG       = -Mfree -O0 -traceback

LLIBS       = -cudalib=cublas,cusolver,cufft,nccl -cuda

# Redefine the standard list of O1 and O2 objects
SOURCE_O1  := pade_fit.o minimax_dependence.o wave_window.o
SOURCE_O2  := pead.o

# --- Library compilers ---
CPP_LIB     = $(CPP)
FC_LIB      = $(FC)
CC_LIB      = $(CC)
CFLAGS_LIB  = -O -w $(VASP_TARGET_CPU)
FFLAGS_LIB  = -O1 -Mfixed $(VASP_TARGET_CPU)
FREE_LIB    = $(FREE)

OBJECTS_LIB = linpack_double.o

# Parser library (also needs target CPU to avoid Illegal instruction)
CXX_PARS    = nvc++ --no_warnings $(VASP_TARGET_CPU)

# --- NVHPC root (auto-detected) ---
NVROOT      =$(shell which nvfortran | awk -F /compilers/bin/nvfortran '{ print $$1 }')

# --- Quadruple precision emulation (mandatory) ---
QD         ?= $(NVROOT)/compilers/extras/qd
LLIBS      += -L$(QD)/lib -lqdmod -lqd
INCS       += -I$(QD)/include/qd

# --- Intel MKL for FFTW, BLAS, LAPACK, and ScaLAPACK ---
# MKL provides runtime CPU dispatch — works on both Intel Icelake
# and AMD Rome nodes without illegal instruction issues.
MKLROOT    ?= /opt/intel/oneapi/mkl/2024.2
LLIBS_MKL   = -L$(MKLROOT)/lib/intel64 -lmkl_scalapack_lp64 -lmkl_blacs_openmpi_lp64 -Mmkl

LLIBS      += $(LLIBS_MKL)
INCS       += -I$(MKLROOT)/include/fftw

# --- HDF5 (optional — disabled) ---
#CPP_OPTIONS+= -DVASP_HDF5
#HDF5_ROOT  ?= /path/to/your/hdf5/installation
#LLIBS      += -L$(HDF5_ROOT)/lib -lhdf5_fortran
#INCS       += -I$(HDF5_ROOT)/include

# --- cusolvermp (optional — disabled) ---
#CPP_OPTIONS+= -DCUSOLVERMP -DCUBLASMP
#LLIBS      += -cudalib=cusolvermp,cublasmp -lnvhpcwrapcal

# --- Wannier90 interface (optional — disabled) ---
#CPP_OPTIONS    += -DVASP2WANNIER90
#WANNIER90_ROOT ?= /path/to/your/wannier90/installation
#LLIBS          += -L$(WANNIER90_ROOT)/lib -lwannier

# --- Add -gpu=tripcount:host for NV HPC-SDK > 25.1 ---
NVFORTRAN_VERSION := $(shell nvfortran --version | sed -n '2s/^nvfortran \([0-9.]*\).*/\1/p')
 define greater_or_equal
$(shell printf '%s\n%s\n' '$(1)' '$(2)' | sort -V | head -n1 | grep -q '$(2)' && echo true || echo false)
endef
ifeq ($(call greater_or_equal,$(NVFORTRAN_VERSION),25.1),true)
    CC  += -gpu=tripcount:host
    FC  += -gpu=tripcount:host
endif
